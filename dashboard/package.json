{
  "name": "routeplane-ce-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Routeplane Community Edition Console — a self-hosted dashboard for the CE gateway (Apache-2.0). Talks only to the CE data plane; enterprise features are shown as upgrade prompts.",
