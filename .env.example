# Routeplane Community Edition — provider secrets.
# Copy to `.env` and fill in the provider key(s) you use. These are referenced by
# configs/keys.json as env:OPENAI_API_KEY etc., resolved server-side only — a
# client's key never reaches an upstream provider.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional — Azure OpenAI (also set AZURE_OPENAI_ENDPOINT / AZURE_OPENAI_DEPLOYMENT
# in this file if you route to it).
AZURE_OPENAI_API_KEY=

# Optional — log filter (default: routeplane=info).
RUST_LOG=routeplane=info
