# Rust build artifacts
/target/
benchmarks/target/

# Local environment / secrets (provider API keys live here — never commit)
.env
.env.*
!.env.example

# Virtual-key registry — maps gateway keys to provider keys; environment- and
# tenant-specific, must never be committed. Use configs/keys.example.json as the
# template. Backups of the registry are equally secret.
configs/keys.json
configs/keys.json.bak
configs/*.bak
*.bak

# Runtime custom-provider registry — written by the authed /v1/providers API and
# holds UPSTREAM provider keys (0600), exactly like keys.json. The `.tmp` is the
# atomic-write staging file; both must never be committed.
configs/providers.json
configs/providers.json.tmp

# Console account registry — written by /v1/console/signup and holds argon2id
# PASSWORD HASHES (0600); same never-committed posture as providers.json. The
# `.tmp` is the atomic-write staging file.
configs/console-accounts.json
configs/console-accounts.json.tmp

# Console SPA — deps and build output are produced by the build (npm / the
# console-builder Docker stage), never committed. node_modules is a dev symlink.
dashboard/node_modules
dashboard/dist

# cargo-about scratch when regenerating THIRD_PARTY_NOTICES.md
/about-scratch/

# OS / editor junk
.DS_Store

# TypeScript incremental build cache (dashboard)
dashboard/*.tsbuildinfo
